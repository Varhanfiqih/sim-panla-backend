{
  "info": {
    "name": "SIM-PANLA API GET Manual Testing",
    "description": "Collection untuk pengujian manual API SIM-PANLA di Postman. Jalankan request Login terlebih dahulu agar token tersimpan otomatis.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://sim-panla.my.id"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "nip",
      "value": "ISI_NIP_KAMU"
    },
    {
      "key": "password",
      "value": "ISI_PASSWORD_KAMU"
    },
    {
      "key": "schedule_id",
      "value": "1"
    },
    {
      "key": "journal_id",
      "value": "1"
    },
    {
      "key": "student_id",
      "value": "1"
    },
    {
      "key": "period_id",
      "value": "1"
    },
    {
      "key": "subject_id",
      "value": "1"
    },
    {
      "key": "category_id",
      "value": "1"
    },
    {
      "key": "item_no",
      "value": "1"
    },
    {
      "key": "date",
      "value": "2026-07-13"
    }
  ],
  "item": [
    {
      "name": "00 - Auth",
      "item": [
        {
          "name": "POST Login - Simpan Token Otomatis",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "login"
              ],
              "query": []
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nip\": \"{{nip}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login response is OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const token = json && json.data ? json.data.token : null;",
                  "if (token) {",
                  "    pm.collectionVariables.set('token', token);",
                  "    pm.environment.set('token', token);",
                  "    console.log('Token saved:', token);",
                  "} else {",
                  "    console.warn('Token not found in response.');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
